# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js compile and build cache
/.next/
/out/
.turbo/
.cache/

# production
/build
dist/

# misc system assets
.DS_Store
*.pem
Thumbs.db
db.crypt

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
next-development.log
*.log

# vercel deployment environment
.vercel

# typescript build info
*.tsbuildinfo
next-env.d.ts

# ── 🔐 SECURE LOCAL ENVIRONMENT VARIABLES ──
# Block local variables from leaking to GitHub and breaking production builds
.env.local
.env.development.local
.env.production.local
.env.*.local

# ── 🛠️ IDE, EDITORS AND SYSTEM CACHE ──
# Blocks local IDE workspace settings from cluttering the deployment pipeline
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp